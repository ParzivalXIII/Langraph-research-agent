{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Request",
  "description": "User-submitted research query with search parameters",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "minLength": 3,
      "maxLength": 500,
      "description": "Research question or topic (3–500 characters)"
    },
    "depth": {
      "type": "string",
      "enum": ["basic", "intermediate", "deep"],
      "default": "intermediate",
      "description": "Search breadth: basic (5 sources), intermediate (10), deep (maximum per budget)"
    },
    "max_sources": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 10,
      "description": "Maximum sources to retrieve (1–50)"
    },
    "time_range": {
      "type": "string",
      "enum": ["day", "week", "month", "year", "all"],
      "default": "all",
      "description": "Recency filter"
    }
  },
  "required": ["query"],
  "additionalProperties": false,
  "examples": [
    {
      "query": "What are the latest advances in quantum computing in 2026?",
      "depth": "intermediate",
      "max_sources": 10,
      "time_range": "month"
    },
    {
      "query": "climate change mitigation strategies",
      "depth": "basic"
    }
  ]
}

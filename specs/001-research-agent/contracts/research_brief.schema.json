{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Brief",
  "description": "Structured research brief synthesized from retrieved sources",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000,
      "description": "Concise narrative summary (50–2000 chars)"
    },
    "key_points": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "minItems": 1,
      "maxItems": 10,
      "description": "Bullet-point highlights (1–10 items)"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SourceRecord"
      },
      "minItems": 1,
      "description": "Supporting sources used in synthesis"
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 500
      },
      "maxItems": 20,
      "description": "Any unresolved conflicts between sources (optional)"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score (0.0=no evidence, 1.0=high agreement)"
    }
  },
  "required": ["summary", "key_points", "sources", "confidence_score"],
  "additionalProperties": false,
  "definitions": {
    "SourceRecord": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Source title"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Source URL (must be valid HTTP(S))"
        },
        "relevance": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Relevance score"
        },
        "snippet": {
          "type": "string",
          "maxLength": 500,
          "description": "Optional excerpt from source"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when source was retrieved"
        }
      },
      "required": ["title", "url", "relevance"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "summary": "Recent developments in quantum computing show significant progress in error correction and qubit scaling. Both IBM and Google have announced new processors with hundreds to thousands of qubits, bringing practical quantum advantage closer to reality.",
      "key_points": [
        "IBM released Condor processor with 1121 qubits",
        "Google announced Willow with improved error correction",
        "Quantum advantage for specific applications now achievable"
      ],
      "sources": [
        {
          "title": "IBM Announces Condor — World's Largest Quantum Processor",
          "url": "https://example.com/ibm-condor",
          "relevance": 0.95,
          "snippet": "IBM has revealed Condor, the most powerful quantum processor...",
          "retrieved_at": "2026-03-26T10:30:00Z"
        },
        {
          "title": "Google's Willow Quantum Chip Breakthrough",
          "url": "https://example.com/google-willow",
          "relevance": 0.92,
          "snippet": "Google's new Willow chip demonstrates exponential error suppression...",
          "retrieved_at": "2026-03-25T14:15:00Z"
        }
      ],
      "contradictions": [],
      "confidence_score": 0.88
    }
  ]
}

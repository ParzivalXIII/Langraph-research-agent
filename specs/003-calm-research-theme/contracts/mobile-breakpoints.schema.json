{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://langraph-research.example.com/schemas/mobile-breakpoints.json",
  "title": "Calm Research Theme Responsive Breakpoints",
  "description": "Schema for mobile-first responsive design breakpoints",
  "type": "object",
  "properties": {
    "breakpoints": {
      "type": "object",
      "description": "CSS media query breakpoints",
      "properties": {
        "mobile": {
          "type": "object",
          "description": "Mobile phone breakpoint",
          "properties": {
            "min_width": {
              "type": "integer",
              "description": "Minimum viewport width in pixels",
              "default": 375,
              "examples": [
                375
              ]
            },
            "max_width": {
              "type": "integer",
              "description": "Maximum viewport width in pixels (exclusive)",
              "default": 768,
              "examples": [
                768
              ]
            },
            "padding": {
              "type": "integer",
              "description": "Container padding in pixels",
              "default": 8,
              "examples": [
                8
              ]
            },
            "gap": {
              "type": "integer",
              "description": "Component gap/spacing in pixels",
              "default": 4,
              "examples": [
                4
              ]
            },
            "font_size_body": {
              "type": "integer",
              "description": "Body text font size in pixels",
              "default": 14,
              "examples": [
                14
              ]
            },
            "font_size_heading": {
              "type": "integer",
              "description": "Heading font size in pixels",
              "default": 18,
              "examples": [
                18
              ]
            }
          },
          "required": [
            "min_width",
            "max_width"
          ],
          "additionalProperties": false
        },
        "tablet": {
          "type": "object",
          "description": "Tablet breakpoint",
          "properties": {
            "min_width": {
              "type": "integer",
              "description": "Minimum viewport width in pixels",
              "default": 768,
              "examples": [
                768
              ]
            },
            "max_width": {
              "type": "integer",
              "description": "Maximum viewport width in pixels (exclusive)",
              "default": 1920,
              "examples": [
                1920
              ]
            },
            "padding": {
              "type": "integer",
              "description": "Container padding in pixels",
              "default": 12,
              "examples": [
                12
              ]
            },
            "gap": {
              "type": "integer",
              "description": "Component gap/spacing in pixels",
              "default": 8,
              "examples": [
                8
              ]
            },
            "font_size_body": {
              "type": "integer",
              "description": "Body text font size in pixels",
              "default": 15,
              "examples": [
                15
              ]
            },
            "font_size_heading": {
              "type": "integer",
              "description": "Heading font size in pixels",
              "default": 20,
              "examples": [
                20
              ]
            }
          },
          "required": [
            "min_width",
            "max_width"
          ],
          "additionalProperties": false
        },
        "desktop": {
          "type": "object",
          "description": "Desktop breakpoint (default)",
          "properties": {
            "min_width": {
              "type": "integer",
              "description": "Minimum viewport width in pixels",
              "default": 1920,
              "examples": [
                1920
              ]
            },
            "padding": {
              "type": "integer",
              "description": "Container padding in pixels",
              "default": 16,
              "examples": [
                16
              ]
            },
            "gap": {
              "type": "integer",
              "description": "Component gap/spacing in pixels",
              "default": 16,
              "examples": [
                16
              ]
            },
            "font_size_body": {
              "type": "integer",
              "description": "Body text font size in pixels",
              "default": 16,
              "examples": [
                16
              ]
            },
            "font_size_heading": {
              "type": "integer",
              "description": "Heading font size in pixels",
              "default": 24,
              "examples": [
                24
              ]
            }
          },
          "required": [
            "min_width"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "mobile",
        "tablet",
        "desktop"
      ],
      "additionalProperties": false
    },
    "touch_targets": {
      "type": "object",
      "description": "Minimum touch target sizes for accessibility",
      "properties": {
        "minimum_width": {
          "type": "integer",
          "description": "Minimum touch target width in pixels (per WCAG AAA)",
          "default": 44,
          "examples": [
            44
          ]
        },
        "minimum_height": {
          "type": "integer",
          "description": "Minimum touch target height in pixels",
          "default": 44,
          "examples": [
            44
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "breakpoints"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "breakpoints": {
        "mobile": {
          "min_width": 375,
          "max_width": 768,
          "padding": 8,
          "gap": 4,
          "font_size_body": 14,
          "font_size_heading": 18
        },
        "tablet": {
          "min_width": 768,
          "max_width": 1920,
          "padding": 12,
          "gap": 8,
          "font_size_body": 15,
          "font_size_heading": 20
        },
        "desktop": {
          "min_width": 1920,
          "padding": 16,
          "gap": 16,
          "font_size_body": 16,
          "font_size_heading": 24
        }
      },
      "touch_targets": {
        "minimum_width": 44,
        "minimum_height": 44
      }
    }
  ]
}

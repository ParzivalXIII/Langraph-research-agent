# Research Agent Configuration (.env)
# Copy to .env and fill in actual values for local development

# Tavily API Configuration
TAVILY_API_KEY=your-tavily-api-key-here

# OpenRouter LLM Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL_ID=openai/gpt-4-turbo

# Database Configuration
DATABASE_URL=sqlite:///./research_agent.db
# For PostgreSQL: postgresql://user:password@localhost:5432/research_agent

# Redis Configuration (optional, for Phase 3+)
REDIS_URL=redis://localhost:6379/0

# Logging Configuration
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL

# Feature Flags (optional, Phase 4+)
ENABLE_PERSISTENCE=False
ENABLE_CACHING=False
